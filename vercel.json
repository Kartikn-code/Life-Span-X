{
    "version": 2,
    "experimentalServices": {
        "frontend": {
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "entrypoint": "backend/app.py",
            "routePrefix": "/api"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "backend/app.py"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
